# Frontend build-time env (Vite). Copy to .env.local for dev; set in the Vercel
# project for prod. All optional — sensible defaults keep dev working unset.

# Base URL for the SMPL-X model assets (smplx_neutral.json/.bin). Unset → bundled
# "./smplx" (dev). In prod point at the public smplx-model GCS bucket:
VITE_SMPLX_BASE=https://storage.googleapis.com/buildday-499318-smplx-model

# Optional Vapi STT (leave unset to keep typed text as the trigger):
# VITE_VAPI_PUBLIC_KEY=
# VITE_VAPI_ASSISTANT_ID=
